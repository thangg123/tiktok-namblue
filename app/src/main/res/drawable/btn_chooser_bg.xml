<?xml version="1.0" encoding="utf-8"?>
<!-- D-pad focus states: focused button glows accent with a white ring; idle is a dim outline. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#22A7F0" />
            <corners android:radius="16dp" />
            <stroke android:width="3dp" android:color="#FFFFFF" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1B86C9" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#16222E" />
            <corners android:radius="16dp" />
            <stroke android:width="2dp" android:color="#33485E" />
        </shape>
    </item>
</selector>
